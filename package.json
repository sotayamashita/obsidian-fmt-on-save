{
	"name": "obsidian-fmt-on-save",
	"version": "0.1.3",
	"description": "Run any external formatter on save in Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "0-BSD",
	"packageManager": "pnpm@10.32.1",
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "25.4.0",
		"esbuild": "0.27.3",
		"eslint": "^10.0.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"jiti": "2.6.1",
		"oxfmt": "^0.37.0",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"obsidian": "1.12.3"
	}
}
