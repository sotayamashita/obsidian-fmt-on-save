{
	"name": "fmt-on-save",
	"version": "1.0.3",
	"description": "Run any external formatter on save in Obsidian",
	"keywords": [],
	"license": "0-BSD",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "pnpm typecheck && node esbuild.config.mjs production",
		"lint": "oxlint && eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"prepare": "husky"
	},
	"dependencies": {
		"obsidian": "1.12.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@eslint/js": "10.0.1",
		"@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
		"@types/node": "25.4.0",
		"@vitest/coverage-v8": "^4.0.18",
		"esbuild": "0.27.3",
		"eslint": "^10.0.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"eslint-plugin-oxlint": "^1.51.0",
		"globals": "17.4.0",
		"husky": "^9.1.7",
		"jiti": "2.6.1",
		"nano-staged": "^0.9.0",
		"oxfmt": "^0.37.0",
		"oxlint": "^1.53.0",
		"secretlint": "^11.3.1",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.0",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.32.1"
}
